# DataForSEO — sign up at https://dataforseo.com, get credentials from Dashboard → API Access
DATAFORSEO_LOGIN=your_login_email
DATAFORSEO_PASSWORD=your_api_password

# Anthropic — get API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# Webhook security (optional — leave empty for open access in dev)
WEBHOOK_SECRET=

# Go High Level — create a Private Integration App in GHL Settings → Integrations
# Scopes needed: conversations.message.write, conversations.message.readonly
GHL_API_KEY=your_ghl_private_integration_api_key
GHL_LOCATION_ID=your_ghl_location_id

# CTA booking link
BOOKING_URL=https://your-booking-link.com
